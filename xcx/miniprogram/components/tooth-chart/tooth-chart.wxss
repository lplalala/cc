.chart-container {
  width: 360rpx;
  margin: 0 auto;
}

.teeth-row {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
}

.teeth-group {
  display: flex;
  flex-wrap: wrap;
  width: 150rpx;              /* 每象限总宽度，容纳4颗牙 */
  justify-content: center;
  align-items: center;
}

/* 每个牙位小格子 */
.tooth {
  width: 34rpx;
  height: 34rpx;
  display: flex;              /* 开启弹性布局 */
  align-items: center;        /* 垂直居中 */
  justify-content: center;    /* 水平居中 */
  font-size: 16rpx;
  border-radius: 4rpx;
  margin: 2rpx;
  background: #f5f5f5;
  color: #333;
  line-height: 1;             /* 行高重置，避免偏移 */
  text-align: center;
  box-sizing: border-box;
  transition: 0.15s;
}

/* 选中状态：金色填充、白色数字 */
.tooth.selected {
  background: #c9a44b;
  color: #fff;
  font-weight: bold;
}

/* 隐藏未选中的牙位 */
.tooth.hidden {
  background: transparent;
  color: transparent;
  border: 1rpx solid transparent;
  pointer-events: none;
}

/* 垂直分隔线 */
.v-line {
  width: 2rpx;
  height: 100rpx;
  background: #c9a44b;
  margin: 0 8rpx;
}

/* 水平分隔线 */
.h-line {
  width: 100%;
  height: 2rpx;
  background: #c9a44b;
  margin: 4rpx 0;
}