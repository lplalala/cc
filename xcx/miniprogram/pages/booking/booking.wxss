/* ======== 自助挂号 — 日历式预约 ======== */
.container { padding: 30rpx; }
.title { font-size: 40rpx; font-weight: bold; margin-bottom: 30rpx; display: block; color: #1A1A1A; }
.section { margin-bottom: 30rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.section-title { font-size: 30rpx; font-weight: bold; color: #1A1A1A; }
.add-btn { background: #1A8CFF; color: white; font-size: 24rpx; padding: 8rpx 24rpx; border-radius: 8rpx; }

/* 就诊人横向滑动 */
.patient-scroll { white-space: nowrap; padding: 8rpx 0; }
.patient-chip {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: #F0F4F8;
  padding: 16rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  min-width: 120rpx;
}
.patient-chip.active { background: #EDF6FF; border-color: #1A8CFF; }
.chip-name { font-size: 28rpx; font-weight: 600; }
.chip-phone { font-size: 22rpx; color: #888; }

/* ======== 日历网格 ======== */
.calendar-week {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 6rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 12rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  overflow: visible;
}

.cal-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 14rpx 2rpx;
  border-radius: 12rpx;
  position: relative;
  transition: all 0.15s;
  min-width: 0;
}
.cal-item.active { background: #1A8CFF; }
.cal-item.active .cal-weekday,
.cal-item.active .cal-day,
.cal-item.active .cal-month { color: #FFFFFF; }
.cal-item.past { opacity: 0.35; pointer-events: none; }

.cal-weekday { font-size: 22rpx; color: #999; margin-bottom: 4rpx; }
.cal-day { font-size: 32rpx; font-weight: 700; color: #1A1A1A; }
.cal-month { font-size: 20rpx; color: #999; margin-top: 2rpx; }

.today-dot {
  width: 8rpx; height: 8rpx;
  background: #FF7F32;
  border-radius: 50%;
  position: absolute; bottom: 6rpx;
}
.cal-item.active .today-dot { background: #FFFFFF; }

/* ======== 时段卡片 ======== */
.time-grid { display: flex; flex-wrap: wrap; gap: 16rpx; }
.time-card {
  width: calc(50% - 8rpx);
  background: #FFFFFF;
  padding: 24rpx 0;
  text-align: center;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  border: 2rpx solid transparent;
  transition: all 0.15s;
}
.time-card.active { border-color: #1A8CFF; background: #EDF6FF; }
.time-card.full { opacity: 0.4; pointer-events: none; }
.time-card.past { opacity: 0.35; pointer-events: none; }
.time-text { font-size: 26rpx; color: #1A1A1A; display: block; margin-bottom: 8rpx; }
.time-remain { font-size: 22rpx; color: #1A8CFF; font-weight: 600; }
.time-full { font-size: 22rpx; color: #F44336; }

.confirm-btn { margin-top: 30rpx; width: 100%; }
.empty { color: #999; text-align: center; padding: 40rpx; }
