/* ========================================
   电子质保卡 — 京东礼品卡风格
   深蓝渐变 + 金色点缀 + 牙位图右侧居中
   ======================================== */
.container { padding: 30rpx; background: #EDF1F5; min-height: 100vh; }

/* ======== 卡片主体 ======== */
.warranty-card {
  position: relative;
  background: linear-gradient(160deg, #1A6FB0 0%, #0E4A7A 40%, #0A3B5A 100%);
  border-radius: 24rpx;
  margin-bottom: 36rpx;
  padding: 32rpx 28rpx 24rpx;
  color: #FFFFFF;
  box-shadow: 0 8rpx 30rpx rgba(10,60,90,0.35);
  overflow: hidden;
}

.warranty-card.expired { filter: grayscale(0.5); opacity: 0.75; }

/* ======== 顶部 ======== */
.card-top {
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.12);
  padding-bottom: 16rpx;
  position: relative;
}

.card-clinic {
  font-size: 22rpx;
  color: rgba(255,255,255,0.65);
  letter-spacing: 4rpx;
}

.card-title-row { display: flex; flex-direction: column; margin-top: 4rpx; }

.card-title {
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: #D4AF37;
  text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
}

.card-subtitle {
  font-size: 18rpx;
  color: rgba(255,255,255,0.4);
  letter-spacing: 4rpx;
  margin-top: 4rpx;
}

.status-stamp {
  position: absolute;
  right: 0; top: 0;
  width: 90rpx; height: 90rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  transform: rotate(15deg);
  font-size: 24rpx; font-weight: 700;
  border: 3rpx solid;
}
.active-stamp { border-color: #4CAF50; color: #4CAF50; background: rgba(76,175,80,0.1); }
.expired-stamp { border-color: #F44336; color: #F44336; background: rgba(244,67,54,0.1); }

/* ======== 信息区（持卡人+项目+品牌）+ 牙位图浮动右侧 ======== */
.card-body {
  position: relative;
  padding-right: 110rpx;    /* 给牙位图留空间 */
}

.patient-row { margin-bottom: 8rpx; }
.patient-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  display: block;
  margin-bottom: 4rpx;
}
.patient-name {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.info-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 6rpx;
}
.info-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  width: 120rpx;
  flex-shrink: 0;
}
.info-value { font-size: 26rpx; color: rgba(255,255,255,0.9); }

/* 牙位图漂浮在信息区右侧，垂直居中 */
.tooth-float {
  position: absolute;
  right: 30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 100rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.tooth-float tooth-chart {
  transform: scale(0.42);
  transform-origin: center center;
}

/* ======== 分项质保 ======== */
.divider { height: 1rpx; background: rgba(255,255,255,0.1); margin: 14rpx 0; }

.items-title { font-size: 24rpx; color: rgba(255,255,255,0.5); margin-bottom: 10rpx; }

.warranty-item {
  background: rgba(255,255,255,0.06);
  border-radius: 12rpx;
  padding: 14rpx 18rpx;
  margin-bottom: 10rpx;
}

.item-header { display: flex; align-items: center; gap: 8rpx; margin-bottom: 4rpx; }
.item-icon { font-size: 28rpx; }
.item-name { font-size: 28rpx; font-weight: 600; }

.lifetime-badge {
  font-size: 20rpx;
  background: linear-gradient(135deg, #D4AF37, #F0D060);
  color: #3D2B00;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 700;
}
.active-badge {
  font-size: 20rpx;
  background: rgba(76,175,80,0.2);
  color: #81C784;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}
.expired-badge {
  font-size: 20rpx;
  background: rgba(244,67,54,0.2);
  color: #EF9A9A;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

.item-dates { font-size: 22rpx; color: rgba(255,255,255,0.55); padding-left: 36rpx; }

/* ======== 普通项目日期 ======== */
.date-label { font-size: 24rpx; color: rgba(255,255,255,0.5); display: block; margin-bottom: 4rpx; }
.date-value { font-size: 26rpx; color: rgba(255,255,255,0.9); }

/* ======== 底部 ======== */
.card-bottom { margin-top: 20rpx; }
.bottom-line { height: 1rpx; background: rgba(212,175,55,0.4); margin-bottom: 8rpx; }
.bottom-text {
  font-size: 18rpx;
  color: rgba(255,255,255,0.3);
  letter-spacing: 2rpx;
  text-align: center;
  display: block;
}

/* ======== 过期遮罩 ======== */
.expired-overlay {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) rotate(-25deg);
  pointer-events: none;
}
.expired-text {
  font-size: 120rpx;
  font-weight: 900;
  color: rgba(255,255,255,0.12);
  white-space: nowrap;
}

/* ======== 通用 ======== */
.empty { text-align: center; color: #999; margin-top: 100rpx; }
.back-home-box { margin-top: 40rpx; text-align: center; }
.back-home-btn {
  background: linear-gradient(135deg, #1A6FB0, #0A3B5A);
  color: white;
  border-radius: 40rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
}
