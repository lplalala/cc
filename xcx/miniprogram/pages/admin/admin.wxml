<!--pages/admin/admin.wxml-->
<!-- 后台管理：轮播图、医生、质保卡 -->
<view class="admin-container">
  <view class="tab-bar">
    <text class="{{tab==0?'active':''}}" bindtap="switchTab" data-index="0">轮播图</text>
    <text class="{{tab==1?'active':''}}" bindtap="switchTab" data-index="1">医生</text>
    <text class="{{tab==2?'active':''}}" bindtap="switchTab" data-index="2">质保卡</text>
    <text class="{{tab==3?'active':''}}" bindtap="switchTab" data-index="3">就诊人</text>
    <text class="{{tab==4?'active':''}}" bindtap="switchTab" data-index="4">挂号记录</text>
    <text class="{{tab==5?'active':''}}" bindtap="switchTab" data-index="5">用户列表</text>
    <text class="{{tab==6?'active':''}}" bindtap="switchTab" data-index="6">商品管理</text>
    <text class="{{tab==7?'active':''}}" bindtap="switchTab" data-index="7">订单管理</text>
  </view>

  <!-- ========= 轮播图管理 ========= -->
  <view wx:if="{{tab==0}}" class="panel">
    <button bindtap="addBanner">+ 新增轮播图</button>
    <view wx:for="{{banners}}" wx:key="_id" class="list-item">
      <image src="{{item.imageUrl}}" mode="aspectFill" class="thumb"></image>
      <text class="item-url">{{item.imageUrl}}</text>
      <button size="mini" bindtap="deleteBanner" data-id="{{item._id}}">删除</button>
    </view>
  </view>

  <!-- ========= 医生管理 ========= -->
  <view wx:if="{{tab==1}}" class="panel">
    <button bindtap="addDoctor">+ 新增医生</button>
    <view wx:for="{{doctors}}" wx:key="_id" class="list-item">
      <image src="{{item.avatarUrl}}" class="thumb" mode="aspectFill"></image>
      <view class="info-line">
        <text>{{item.name}}</text>
        <text class="sub">{{item.title}}</text>
      </view>
      <button size="mini" bindtap="editDoctor" data-id="{{item._id}}">编辑</button>
      <button size="mini" bindtap="deleteDoctor" data-id="{{item._id}}">删除</button>
    </view>
  </view>

  <!-- ========= 质保卡管理 ========= -->
  <view wx:if="{{tab==2}}" class="panel">
    <view class="search-bar">
      <input placeholder="搜索号码或姓名" bindinput="onSearchInput" value="{{searchQuery}}" />
    </view>
    <button bindtap="addWarranty">+ 新增质保卡</button>
    <view wx:for="{{warranties}}" wx:key="_id" class="list-item">
      <text>号码：{{item.queryNo}} | 患者：{{item.patientName}}</text>
      <button size="mini" bindtap="editWarranty" data-id="{{item._id}}">编辑</button>
      <button size="mini" bindtap="deleteWarranty" data-id="{{item._id}}">删除</button>
    </view>
  </view>

  <!-- 就诊人列表（新增） -->
  <view wx:if="{{tab==3}}" class="panel">
    <view class="list-item" wx:for="{{patients}}" wx:key="_id">
      <view class="info-line">
        <text>{{item.name}} - {{item.phone}}</text>
        <text class="sub">性别：{{item.gender}} / 年龄：{{item.age}}</text>
      </view>
    </view>
    <view wx:if="{{patients.length===0}}" class="empty">暂无就诊人</view>
  </view>

  <!-- 挂号记录列表 -->
  <view wx:if="{{tab==4}}" class="panel">
    <view class="date-picker-row">
      <text class="picker-label">筛选日期：</text>
      <picker mode="date" value="{{appointmentDate}}" bindchange="onAppointmentDateChange">
        <view class="date-display">{{appointmentDate || '请选择日期'}}</view>
      </picker>
    </view>
    <view class="list-item" wx:for="{{filteredAppointments}}" wx:key="_id">
      <view class="info-line">
        <text>{{item.patientName}} - {{item.phone}}</text>
        <text wx:if="{{item.doctorName}}" class="sub">预约医生：{{item.doctorName}}{{item.doctorTitle ? ' (' + item.doctorTitle + ')' : ''}}</text>
        <text class="sub">日期：{{item.date}} / 时段：{{item.time}}</text>
        <text class="sub">状态：{{item.status}}</text>
      </view>
    </view>
    <view wx:if="{{filteredAppointments.length===0}}" class="empty">当天无预约记录</view>
  </view>

  <!-- 用户列表 -->
  <view wx:if="{{tab==5}}" class="panel">
    <view class="list-item" wx:for="{{users}}" wx:key="_id">
      <view class="info-line">
        <text>昵称：{{item.nickName || '未设置'}}</text>
        <text class="sub">手机号：{{item.phone || '未授权'}}</text>
        <text class="sub">OpenID：{{item.openid}}</text>
      </view>
    </view>
    <view wx:if="{{users.length===0}}" class="empty">暂无用户数据</view>
  </view>

  <!-- ========= 商品管理 ========= -->
  <view wx:if="{{tab==6}}" class="panel">
    <button bindtap="addProduct">+ 新增商品</button>
    <view class="list-item" wx:for="{{products}}" wx:key="_id">
      <image src="{{item.imageUrl || '/images/default-goods-image.png'}}" class="thumb" mode="aspectFill"></image>
      <view class="info-line">
        <text>{{item.name}}</text>
        <text class="sub">¥{{item.price}} | {{item.category || '未分类'}}</text>
        <text class="sub">状态：{{item.status === 'on' ? '🟢上架' : '🔴下架'}}</text>
      </view>
      <button size="mini" bindtap="toggleProduct" data-id="{{item._id}}" data-status="{{item.status}}">
        {{item.status === 'on' ? '下架' : '上架'}}
      </button>
      <button size="mini" bindtap="editProduct" data-id="{{item._id}}">编辑</button>
      <button size="mini" bindtap="deleteProduct" data-id="{{item._id}}">删除</button>
    </view>
  </view>

  <!-- ========= 订单管理 ========= -->
  <view wx:if="{{tab==7}}" class="panel">
    <view class="sub-tabs">
      <text class="{{orderTab=='paid'?'active':''}}" bindtap="switchOrderTab" data-tab="paid">待核销</text>
      <text class="{{orderTab=='refunding'?'active':''}}" bindtap="switchOrderTab" data-tab="refunding">退款中</text>
      <text class="{{orderTab=='verified'?'active':''}}" bindtap="switchOrderTab" data-tab="verified">已核销</text>
      <text class="{{orderTab=='refunded'?'active':''}}" bindtap="switchOrderTab" data-tab="refunded">已退款</text>
    </view>
    <view class="list-item" wx:for="{{adminOrders}}" wx:key="_id">
      <view class="info-line">
        <text>{{item.orderNo}}</text>
        <text wx:if="{{item.isUpgrade}}" class="sub upgrade-hint">⚡升级订单</text>
        <text class="sub">{{item.nickName || '用户'}} | ¥{{item.totalAmount}}</text>
        <text wx:if="{{item.selectedSpec}}" class="sub">规格：{{item.selectedSpec}}</text>
        <!-- 配送方式 -->
        <text class="sub delivery-info">
          {{item.deliveryMethod === 'express' ? '📦 快递配送' : '🏥 到店自取'}}
          <block wx:if="{{item.deliveryMethod === 'express' && item.shippingAddress}}">
            | {{item.shippingAddress.recipientName}} {{item.shippingAddress.recipientPhone}}
          </block>
        </text>
        <text class="sub">{{item.createdAt}}</text>
      </view>
      <button wx:if="{{item.status === 'paid'}}" size="mini" bindtap="verifyOrder" data-id="{{item._id}}">核销</button>
      <button wx:if="{{item.status === 'paid'}}" size="mini" bindtap="refundOrder" data-id="{{item._id}}">退款</button>
      <text wx:if="{{item.status === 'refunding'}}" class="sub refunding-hint">⏳ 退款处理中</text>
    </view>
    <view wx:if="{{adminOrders.length===0}}" class="empty">暂无订单</view>
  </view>

</view>