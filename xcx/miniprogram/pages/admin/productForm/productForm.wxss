/* ======== 商品表单 v2.0 ======== */
.form-container { padding: 30rpx; background: #F5F7FA; min-height: 100vh; }
.form-item { margin-bottom: 24rpx; }
.label { font-size: 28rpx; font-weight: bold; display: block; margin-bottom: 10rpx; color: #1A1A1A; }
.input {
  border: 1rpx solid #DDD; background: white; padding: 18rpx 16rpx;
  border-radius: 12rpx; font-size: 28rpx; width: 100%; box-sizing: border-box;
  line-height: 1.4; min-height: 80rpx;
}
.picker-view {
  border: 1rpx solid #DDD; background: white; padding: 18rpx 16rpx;
  border-radius: 12rpx; font-size: 28rpx; color: #1A1A1A;
}
.textarea {
  border: 1rpx solid #DDD; background: white; padding: 18rpx 16rpx;
  border-radius: 12rpx; font-size: 28rpx; width: 100%; min-height: 160rpx; box-sizing: border-box;
  line-height: 1.5;
}
.radio-label { margin-right: 30rpx; font-size: 28rpx; }
.preview-img { width: 200rpx; height: 200rpx; border-radius: 12rpx; background: #E8F4FD; }
.img-btn { background: #F0F4F8; color: #1A8CFF; border-radius: 12rpx; font-size: 28rpx; border: 1rpx dashed #1A8CFF; }

/* ======== 分区标题 ======== */
.form-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-label { font-size: 28rpx; font-weight: bold; color: #1A1A1A; }
.add-link { font-size: 26rpx; color: #1A8CFF; font-weight: 500; }
.hint { font-size: 24rpx; color: #999; padding: 12rpx 0; }

/* ======== 升级推荐 ======== */
.upgrade-block {
  background: #F5F9FF;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #E0EDF8;
}
.upgrade-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.upgrade-index { font-size: 26rpx; font-weight: 600; color: #1A8CFF; }
.upgrade-block .input { margin-bottom: 12rpx; }

.upgrade-picker-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.mini-label { font-size: 24rpx; color: #999; width: 120rpx; flex-shrink: 0; }
.picker-view-sm {
  flex: 1;
  border: 1rpx solid #DDD;
  background: white;
  padding: 16rpx 14rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #1A1A1A;
}

.upgrade-image-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.upgrade-thumb {
  width: 120rpx; height: 120rpx;
  border-radius: 8rpx; background: #E8F4FD;
}
.mini-upload-btn {
  font-size: 24rpx;
  background: #F0F4F8;
  color: #1A8CFF;
  border-radius: 8rpx;
  padding: 12rpx 20rpx;
  border: 1rpx dashed #1A8CFF;
  line-height: 1.4;
}
.clear-img { font-size: 22rpx; color: #FF4444; padding: 6rpx; }

.nested-section { margin-top: 8rpx; }
.sub-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}
.sub-label { font-size: 24rpx; color: #666; }

.improve-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.improve-label-input {
  flex: 1;
  border: 1rpx solid #DDD; border-radius: 8rpx;
  padding: 14rpx 10rpx; font-size: 24rpx; background: white;
  line-height: 1.4; min-height: 66rpx; box-sizing: border-box;
}
.improve-value-input {
  flex: 1.5;
  border: 1rpx solid #DDD; border-radius: 8rpx;
  padding: 14rpx 10rpx; font-size: 24rpx; background: white;
  line-height: 1.4; min-height: 66rpx; box-sizing: border-box;
}
.spec-delete { font-size: 24rpx; color: #FF4444; padding: 8rpx; flex-shrink: 0; }

/* ======== 保存 ======== */
.save-btn {
  margin-top: 40rpx;
  background: #1A8CFF;
  color: white;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}
.save-btn:active { opacity: 0.85; }
.safe-bottom { height: calc(40rpx + env(safe-area-inset-bottom)); }
