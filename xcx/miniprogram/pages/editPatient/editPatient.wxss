.form { padding: 40rpx; }
.form-item { margin-bottom: 24rpx; }
.label { font-size: 28rpx; display: block; margin-bottom: 8rpx; }
input {
  border: 1rpx solid #ccc;
  padding: 20rpx 16rpx;
  border-radius: 8rpx;
  width: 100%;
  box-sizing: border-box;
  font-size: 30rpx;          /* 文字加大，避免遮挡 */
  height: 80rpx;             /* 固定高度，让提示词完全可见 */
  line-height: 80rpx;
}
.radio-label { margin-right: 40rpx; font-size: 28rpx; }
.save-btn {
  margin-top: 40rpx;
  background: #d4a843;
  color: white;
}