<view class="form">
  <view class="form-item">
    <text class="label">姓名</text>
    <input value="{{name}}" bindinput="onNameInput" placeholder="请输入姓名" />
  </view>
  <view class="form-item">
    <text class="label">手机号</text>
    <input value="{{phone}}" bindinput="onPhoneInput" placeholder="请输入手机号" type="number" maxlength="11" />
  </view>
  <view class="form-item">
    <text class="label">年龄</text>
    <input value="{{age}}" bindinput="onAgeInput" placeholder="请输入年龄" type="number" />
  </view>
  <view class="form-item">
    <text class="label">性别</text>
    <radio-group bindchange="onGenderChange">
      <label class="radio-label"><radio value="男" checked="{{gender==='男'}}" />男</label>
      <label class="radio-label"><radio value="女" checked="{{gender==='女'}}" />女</label>
    </radio-group>
  </view>
  <button class="save-btn" bindtap="save">保存修改</button>
</view>