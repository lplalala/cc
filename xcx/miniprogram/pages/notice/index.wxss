/* ======== 注意事项 — 列表纯标题 + 点击展开图片 ======== */

.container { padding: 24rpx; min-height: 100vh; background: #F5F7FA; }

/* 加载 & 空态 */
.loading-wrap, .empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}
.loading-text { font-size: 28rpx; color: #999; }
.empty-icon { font-size: 80rpx; margin-bottom: 20rpx; }
.empty-text { font-size: 28rpx; color: #999; }

/* ======== 四宫格列表 ======== */
.notice-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 4rpx 0;
}

.notice-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 48rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  transition: transform 0.15s;
  min-height: 160rpx;
}
.notice-card:active { transform: scale(0.97); }

.notice-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
  text-align: center;
  line-height: 1.4;
}

/* ======== 详情页 ======== */
.detail-page {
  min-height: 100vh;
}

.detail-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0 30rpx;
}

.back-btn {
  font-size: 28rpx;
  color: #1A8CFF;
  font-weight: 500;
  flex-shrink: 0;
}

.detail-page-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
  flex: 1;
}

.detail-images {
  /* 占满剩余空间 */
}

.detail-image {
  width: 100%;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  display: block;
}

.detail-empty {
  text-align: center;
  color: #999;
  font-size: 28rpx;
  padding-top: 80rpx;
}
