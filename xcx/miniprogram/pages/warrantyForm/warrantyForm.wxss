/* ======== 质保卡表单 — 清新风格 ======== */
.form-container { padding: 30rpx; background: #F5F7FA; min-height: 100vh; }
.form-item { margin-bottom: 24rpx; }
.label { font-size: 28rpx; font-weight: bold; margin-bottom: 10rpx; display: block; color: #1A1A1A; }
.input {
  border: 1rpx solid #DDD;
  background: white;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 80rpx;
  line-height: 40rpx;
}
.picker-view {
  border: 1rpx solid #DDD; background: white; padding: 16rpx;
  border-radius: 12rpx; font-size: 28rpx;
}
.date-row { display: flex; align-items: center; gap: 10rpx; }
.date-input {
  flex: 1;
  border: 1rpx solid #DDD;
  background: white;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  min-height: 80rpx;
  line-height: 40rpx;
  box-sizing: border-box;
}
.date-sep { font-size: 28rpx; color: #666; }
.sub-section { background: white; border-radius: 16rpx; padding: 20rpx; margin: 20rpx 0; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04); }
.sub-item { display: flex; justify-content: space-between; align-items: center; padding: 12rpx 0; border-bottom: 1rpx solid #EEE; }
.sub-item:last-child { border-bottom: none; }
.sub-name { font-weight: bold; font-size: 28rpx; }
.sub-dates-row { display: flex; align-items: center; gap: 8rpx; flex: 1; max-width: 60%; }
.sub-date-input {
  flex: 1;
  border: 1rpx solid #DDD;
  background: white;
  padding: 14rpx 8rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
  min-height: 70rpx;
  line-height: 36rpx;
  box-sizing: border-box;
}
.save-btn { margin-top: 40rpx; background: #1A8CFF; color: white; border-radius: 16rpx; }
