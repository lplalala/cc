/* ======== 个人中心 — 宝矿力清新风格 ======== */
.profile-container {
  padding: 30rpx;
  background: #F5F7FA;
  min-height: 100vh;
}

/* 用户卡片 */
.user-card {
  background: linear-gradient(135deg, #1A8CFF, #0D6ED6);
  border-radius: 16rpx;
  padding: 30rpx 25rpx;
  display: flex;
  align-items: center;
  color: white;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(26,140,255,0.2);
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-info { flex: 1; min-width: 0; }

.nick-name {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  background: transparent;
  border: none;
  padding: 0;
  margin-bottom: 8rpx;
  width: 100%;
}

.phone-id-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: nowrap;
}

.user-phone { font-size: 26rpx; opacity: 0.9; }

.id-copy-box {
  display: flex;
  align-items: center;
  flex-shrink: 1;
  min-width: 0;
}

.user-id {
  font-size: 24rpx;
  opacity: 0.7;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 200rpx;
  margin-right: 8rpx;
}

.copy-btn {
  font-size: 22rpx;
  color: #FFFFFF;
  padding: 4rpx 12rpx;
  border: 1rpx solid rgba(255,255,255,0.6);
  border-radius: 8rpx;
  flex-shrink: 0;
}

/* 菜单样式 */
.menu-group {
  background: white;
  border-radius: 16rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  font-size: 30rpx;
}
.menu-item:last-child { border-bottom: none; }
.arrow { color: #CCCCCC; font-size: 26rpx; }

.sub-item {
  background: #F8F9FB;
  padding: 20rpx;
  margin: 10rpx 0;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.sub-info { flex: 1; }
.sub-info text { display: block; }
.status { font-size: 24rpx; color: #1A8CFF; }
.sub-actions { display: flex; gap: 10rpx; }
.empty { text-align: center; color: #999; padding: 20rpx; }

/* ======== 预约卡片 — 两行紧凑布局 ======== */
.booking-card {
  background: #F8F9FB;
  padding: 20rpx 24rpx;
  margin: 10rpx 0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  line-height: 1.4;
}
.booking-row-1 {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.booking-doctor {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.booking-time {
  font-size: 26rpx;
  font-weight: 600;
  color: #1A8CFF;
  white-space: nowrap;
}
.booking-row-2 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 6rpx;
}
.booking-patient {
  font-size: 26rpx;
  color: #888;
}
.booking-status {
  font-size: 24rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  white-space: nowrap;
}
.status-pending { color: #1A8CFF; background: #EDF6FF; }
.status-done { color: #52C41A; background: #F0FFF0; }
.status-cancel { color: #999; background: #F0F0F0; }

.booking-actions { margin-top: 8rpx; text-align: right; }
.del-link { font-size: 22rpx; color: #F44336; }

.admin-btn {
  margin-top: 40rpx;
  background: #1A8CFF;
  color: white;
  border-radius: 16rpx;
}
.logout-btn {
  margin-top: 20rpx;
  background: #EEEEEE;
  color: #999;
  border-radius: 16rpx;
}

/* 未登录卡片样式 */
.login-card {
  display: flex;
  justify-content: center;
  align-items: center;
}

.login-hint-box {
  text-align: center;
  padding: 20rpx 0;
}

.login-hint-icon {
  font-size: 60rpx;
  display: block;
  margin-bottom: 12rpx;
}

.login-hint-text {
  font-size: 28rpx;
  color: #ffffff;
  opacity: 0.8;
  display: block;
  margin-bottom: 24rpx;
}

.login-btn {
  background: #FF7F32;
  color: white;
  border-radius: 40rpx;
  padding: 16rpx 50rpx;
  font-size: 28rpx;
}
