/* ======== 下单确认页 ======== */
page { background: #F5F7FA; }
.container { padding: 30rpx; }

/* 通用卡片 */
.card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
  margin-bottom: 20rpx;
}

.product-summary { display: flex; align-items: center; gap: 20rpx; }
.thumb { width: 120rpx; height: 120rpx; border-radius: 12rpx; background: #E8F4FD; flex-shrink: 0; }
.summary-info { flex: 1; }
.name { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 8rpx; }
.unit-price, .qty { font-size: 26rpx; color: #888; display: block; }

/* 服务须知 */
.notice-card {
  border-left: 6rpx solid #FF9800;
  background: #FFF8F0;
}
.notice-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #FF9800;
  display: block;
  margin-bottom: 12rpx;
}
.notice-content {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  display: block;
}

.form-card { }
.label { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 12rpx; color: #1A1A1A; }
.input { border: 1rpx solid #EEE; border-radius: 8rpx; padding: 16rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; line-height: 1.4; min-height: 80rpx; }
.textarea { border: 1rpx solid #EEE; border-radius: 8rpx; padding: 16rpx; font-size: 28rpx; width: 100%; min-height: 120rpx; box-sizing: border-box; line-height: 1.5; }

.amount-card { }
.row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 28rpx; color: #666; }
.row.total { border-top: 1rpx solid #EEE; margin-top: 8rpx; padding-top: 16rpx; color: #1A1A1A; }
.total-num { font-size: 36rpx; font-weight: 700; color: #FF7F32; }

.pay-btn {
  margin-top: 20rpx;
  width: 100%;
  background: #FF7F32;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  line-height: 2.6;
}
.pay-btn:active { opacity: 0.85; }
.pay-btn[disabled] { background: #CCC; }
