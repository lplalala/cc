/* ======== 下单确认页 ======== */
.container { padding: 30rpx; }

.product-summary { display: flex; align-items: center; gap: 20rpx; }
.thumb { width: 120rpx; height: 120rpx; border-radius: 12rpx; background: #E8F4FD; flex-shrink: 0; }
.summary-info { flex: 1; }
.name { font-size: 30rpx; font-weight: 600; display: block; margin-bottom: 8rpx; }
.unit-price, .qty { font-size: 26rpx; color: #888; display: block; }

.form-card { margin-top: 20rpx; }
.label { font-size: 28rpx; font-weight: 600; display: block; margin-bottom: 12rpx; }
.input { border: 1rpx solid #EEE; border-radius: 8rpx; padding: 16rpx; font-size: 28rpx; width: 100%; box-sizing: border-box; }
.textarea { border: 1rpx solid #EEE; border-radius: 8rpx; padding: 16rpx; font-size: 28rpx; width: 100%; min-height: 120rpx; box-sizing: border-box; }

.amount-card { margin-top: 20rpx; }
.row { display: flex; justify-content: space-between; padding: 12rpx 0; font-size: 28rpx; }
.row.total { border-top: 1rpx solid #EEE; margin-top: 8rpx; padding-top: 16rpx; }
.total-num { font-size: 36rpx; font-weight: 700; color: #FF7F32; }

.pay-btn { margin-top: 40rpx; width: 100%; }
