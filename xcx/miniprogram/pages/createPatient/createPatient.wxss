/* 页面背景 */
page {
  background: #F5F7FA;
}

.form {
  padding: 30rpx;
}

.form-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.label {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

/* 输入框样式 */
.input-field {
  border: 1rpx solid #eee;
  background: #fafafa;
  padding: 20rpx 16rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 40rpx;
}

.radio-label {
  display: inline-flex;
  align-items: center;
  font-size: 30rpx;
  margin-right: 48rpx;
}

/* 保存并返回按钮 — 宝矿力主题大按钮 */
.save-btn {
  margin-top: 48rpx;
  background: #1A8CFF;
  color: white;
  border-radius: 16rpx;
  padding: 28rpx 0;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  width: 100%;
}

.save-btn:active {
  transform: scale(0.98);
  background: #1580EB;
}

.save-btn::after {
  border: none;
}