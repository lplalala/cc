/* ======== 授权页 — 宝矿力清新风格 ======== */
.auth-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background: linear-gradient(135deg, #1A8CFF, #0D6ED6);
}

.auth-box {
  text-align: center;
  color: white;
  padding: 60rpx 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.auth-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.auth-desc {
  display: block;
  font-size: 28rpx;
  margin-bottom: 60rpx;
  opacity: 0.8;
}

.auth-btn {
  background: #FF7F32;
  color: white;
  border-radius: 60rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  display: inline-block;
}

.phone-show {
  background: rgba(255,255,255,0.2);
  border-radius: 12rpx;
  padding: 20rpx;
  margin: 30rpx 0 20rpx;
  font-size: 28rpx;
}

.nickname-box { margin: 20rpx 0; }

.label {
  color: white;
  font-size: 26rpx;
  margin-bottom: 8rpx;
  display: block;
}

.nickname-input {
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  font-size: 32rpx;
  color: #333;
  width: 100%;
  box-sizing: border-box;
  text-align: left;
  min-height: 90rpx;
  line-height: 42rpx;
}

.nickname-confirm-btn {
  margin-top: 20rpx;
  background: #FF7F32;
  color: white;
  border-radius: 40rpx;
  font-size: 28rpx;
}

.complete-box { margin-top: 40rpx; }
.complete-text { font-size: 30rpx; color: #fff; }
